{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdedit",
  "version": "0.1.0",
  "identifier": "com.mdedit.app",
  "build": {
    "beforeDevCommand": "npm run dev-vite",
    "beforeBuildCommand": "npm run build-vite",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "MdEdit",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
