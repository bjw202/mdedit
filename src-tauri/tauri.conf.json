{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdedit",
  "version": "0.3.0",
  "identifier": "com.mdedit.app",
  "build": {
    "beforeDevCommand": "npm run dev-vite",
    "beforeBuildCommand": "npm run build-vite",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "MdEdit",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; img-src 'self' data: asset: https://asset.localhost blob:; connect-src 'self' tauri: asset: https://asset.localhost ws://localhost:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
