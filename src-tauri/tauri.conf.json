{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdedit",
  "version": "0.6.2",
  "identifier": "com.mdedit.app",
  "build": {
    "beforeDevCommand": "npm run dev-vite",
    "beforeBuildCommand": "npm run build-vite",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "MdEdit",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
